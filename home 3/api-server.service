[Unit]
Description=Camera API Server
After=network.target
Wants=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi
RuntimeDirectory=picamera
RuntimeDirectoryMode=0755
ExecStartPre=/usr/bin/python3 -c "import json,os; p='/home/pi/camera_settings.json'; d=json.load(open(p)) if os.path.exists(p) else {}; d['wifi_mode']='ap'; d.setdefault('ap_ssid','PiCamera'); d.setdefault('ap_password','picamera123'); json.dump(d,open(p,'w'),indent=2)"
ExecStart=/usr/bin/python3 /home/pi/api_server.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
